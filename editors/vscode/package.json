{
  "name": "rpl-vscode",
  "displayName": "RPL (Rakoda Programming Language)",
  "description": "Syntax highlighting, error checking, autocomplete, dan hover untuk bahasa pemrograman RPL",
  "version": "1.1.0",
  "publisher": "rakoda",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:rpl",
    "onLanguage:rpl-html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rpl",
        "aliases": [
          "RPL",
          "rpl",
          "IPL",
          "ipl"
        ],
        "extensions": [
          ".rpl",
          ".ipl"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "rpl-html",
        "aliases": [
          "RPL HTML",
          "rpl-html"
        ],
        "extensions": [
          ".rpl.html",
          ".ipl.html"
        ],
        "configuration": "./html-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rpl",
        "scopeName": "source.rpl",
        "path": "./syntaxes/rpl.tmLanguage.json"
      },
      {
        "language": "rpl-html",
        "scopeName": "text.html.rpl",
        "path": "./syntaxes/rpl-html.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  }
}
