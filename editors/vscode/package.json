{
  "name": "rpl-vscode",
  "displayName": "RPL (Rakoda Programming Language)",
  "description": "Dukungan syntax highlighting untuk bahasa pemrograman RPL",
  "version": "1.0.0",
  "publisher": "rakoda",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rpl",
        "aliases": ["RPL", "rpl", "IPL", "ipl"],
        "extensions": [".rpl", ".ipl"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "rpl-html",
        "aliases": ["RPL HTML", "rpl-html"],
        "extensions": [".rpl.html", ".ipl.html"],
        "configuration": "./html-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rpl",
        "scopeName": "source.rpl",
        "path": "./syntaxes/rpl.tmLanguage.json"
      },
      {
        "language": "rpl-html",
        "scopeName": "text.html.rpl",
        "path": "./syntaxes/rpl-html.tmLanguage.json"
      }
    ]
  }
}
