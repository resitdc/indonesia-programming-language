{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RPL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#template_strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rpl",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.rpl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.rpl",
          "match": "\\\\."
        }
      ]
    },
    "template_strings": {
      "name": "string.quoted.other.rpl",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.rpl",
          "match": "\\\\."
        },
        {
          "name": "meta.template.expression.rpl",
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.rpl" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.rpl" }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rpl",
          "match": "\\b(jika|maka|jika tidak|selama|ulangi|dalam|selesai|coba|tangkap|lempar|impor|gabung)\\b"
        },
        {
          "name": "keyword.declaration.rpl",
          "match": "\\b(buat|fungsi|kembalikan)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.rpl",
          "match": "\\b(benar|salah)\\b"
        },
        {
          "name": "constant.language.null.rpl",
          "match": "\\bkosong\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.rpl",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.rpl",
          "match": "(\\+|-|\\*|/|%|==|!=|>|<|>=|<=|&&|\\|\\||=)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.rpl",
          "match": "\\b(cetak|tampilkan|baca)\\b"
        },
        {
          "name": "entity.name.function.rpl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  },
  "scopeName": "source.rpl"
}
